# CONST-053 — No-versioned-build-artifacts mandate.

# Build artefacts
/bin/
/build/
/dist/
/out/
*.exe
*.dll
*.so
*.dylib
*.a
*.o
*.test

# Go-specific
/vendor/
coverage.out
*.out
*.cover
profile.cov

# Caches
.cache/
__pycache__/

# Temp + OS state
*.tmp
*.swp
*~
.DS_Store
Thumbs.db
*.orig
*.rej

# Sensitive-data files (CONST-042 + CONST-053(4))
.env
.env.*
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# Generated reports / logs
*.log
htmlcov/

# IDE / personal state
.idea/
.history/
.vscode/
